generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum OwnerType {
  user
  platform
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum MediaType {
  image
  video
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(30)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  avatar_url    String?   @db.VarChar(255)
  is_active     Boolean   @default(true)
  deleted_at    DateTime?
  created_at    DateTime  @default(now())

  recipes        Recipe[]
  comments       Comment[]
  likes          Like[]
  shopping_lists ShoppingList[]
  meal_plans     MealPlan[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// RECIPES
// ─────────────────────────────────────────────────────────────────────────────

model Recipe {
  id           Int       @id @default(autoincrement())
  user_id      Int?
  owner_type   OwnerType @default(user)
  title        String    @db.VarChar(255)
  description  String?
  instructions String?
  prep_time    Int?
  created_at   DateTime  @default(now())

  user               User?              @relation(fields: [user_id], references: [id])
  recipe_ingredients RecipeIngredient[]
  comments           Comment[]
  likes              Like[]
  meal_plan_recipes  MealPlanRecipe[]
  recipe_media       RecipeMedia[]

  @@map("recipes")
}

// ─────────────────────────────────────────────────────────────────────────────
// INGREDIENTS
// ─────────────────────────────────────────────────────────────────────────────

model Ingredient {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  recipe_ingredients  RecipeIngredient[]
  shopping_list_items ShoppingListItem[]

  @@map("ingredients")
}

model RecipeIngredient {
  recipe_id     Int
  ingredient_id Int
  quantity      Decimal @db.Decimal(10, 2)
  unit          String  @db.VarChar(50)

  recipe     Recipe     @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])

  @@id([recipe_id, ingredient_id])
  @@map("recipe_ingredients")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMENTS (struttura ad albero: parent_id per le risposte)
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id         Int      @id @default(autoincrement())
  recipe_id  Int
  user_id    Int?
  parent_id  Int?
  content    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  recipe  Recipe    @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  user    User?     @relation(fields: [user_id], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@map("comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// LIKES
// ─────────────────────────────────────────────────────────────────────────────

model Like {
  user_id    Int
  recipe_id  Int
  created_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@id([user_id, recipe_id])
  @@map("likes")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEAL PLANS
// ─────────────────────────────────────────────────────────────────────────────

model MealPlan {
  id         Int      @id @default(autoincrement())
  user_id    Int
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  created_at DateTime @default(now())

  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meal_plan_recipes MealPlanRecipe[]
  shopping_lists    ShoppingList[]

  @@map("meal_plans")
}

model MealPlanRecipe {
  meal_plan_id Int
  recipe_id    Int
  planned_date DateTime @db.Date
  meal_type    MealType

  meal_plan MealPlan @relation(fields: [meal_plan_id], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@id([meal_plan_id, recipe_id, planned_date])
  @@map("meal_plan_recipes")
}

// ─────────────────────────────────────────────────────────────────────────────
// SHOPPING LISTS
// ─────────────────────────────────────────────────────────────────────────────

model ShoppingList {
  id           Int      @id @default(autoincrement())
  user_id      Int
  meal_plan_id Int?
  created_at   DateTime @default(now())

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meal_plan MealPlan? @relation(fields: [meal_plan_id], references: [id])
  items     ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id               Int     @id @default(autoincrement())
  shopping_list_id Int
  ingredient_id    Int
  quantity         Decimal @db.Decimal(10, 2)
  unit             String  @db.VarChar(50)
  checked          Boolean @default(false)

  shopping_list ShoppingList @relation(fields: [shopping_list_id], references: [id], onDelete: Cascade)
  ingredient    Ingredient   @relation(fields: [ingredient_id], references: [id])

  @@map("shopping_list_items")
}

model RecipeMedia {
  id         Int       @id @default(autoincrement())
  recipe_id  Int
  url        String    @db.VarChar(500)
  media_type MediaType
  order      Int       @default(0)
  created_at DateTime  @default(now())

  recipe Recipe @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@map("recipe_media")
}